# Test env — local Supabase by default. Safe to commit: the URL is localhost and
# the key is the Supabase CLI local publishable key (a public dev token, NOT a
# real secret). Loaded by vitest (mode "test") on top of .env, so it overrides
# .env's remote SUPABASE_* while .env still supplies OPENROUTER_API_KEY.
#
# This is the `Publishable` value from `supabase status`. If your local stack
# prints a different one, swap SUPABASE_KEY below.
# To run the suite against remote instead, see .env.test.remote.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# OPENROUTER_API_KEY is intentionally NOT set here — it comes from .env (gitignored).
# CI supplies it as a repo secret. Tests that hit OpenRouter fail loudly if absent.
