---
import Layout from "@/layouts/Layout.astro";
import SignInForm from "@/components/auth/SignInForm";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Logowanie — Omnilister AI">
  <div class="flex min-h-screen items-center justify-center p-4" style="background-color: var(--dt-color-surface);">
    <div class="w-full max-w-sm p-8"
      style="background-color: var(--dt-color-canvas); border: 1px solid var(--dt-color-hairline); border-radius: var(--dt-radius-lg); box-shadow: var(--dt-shadow-4);">

      <a href="/" class="mb-6 block text-center text-sm font-semibold" style="color: var(--dt-color-primary);">
        ← Omnilister AI
      </a>
      <h1 class="mb-6 text-center text-2xl font-semibold" style="color: var(--dt-color-ink);">
        Zaloguj się
      </h1>
      <SignInForm serverError={error} client:load />
      <p class="mt-4 text-center text-sm" style="color: var(--dt-color-slate);">
        Nie masz konta?{" "}
        <a href="/auth/signup" style="color: var(--dt-color-primary);">Zarejestruj się</a>
      </p>
    </div>
  </div>
</Layout>
