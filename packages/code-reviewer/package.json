{
  "name": "@omnilister/code-reviewer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "AI-powered code reviewer built on the Vercel AI SDK + OpenRouter.",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "agents": "^0.17.0",
    "ai": "^6.0.213",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
