# Remote override template — run the SAME integration suite against a remote
# Supabase instead of local. This file is a template; it carries no real secrets.
#
# Usage: copy your real values into .env.test.local (gitignored), which vitest
# loads at higher priority than .env.test:
#
#   cp .env.test.remote .env.test.local   # then fill in real values
#
# The remote project must contain the same two seeded users as supabase/seed.sql
# (usera@test.local / userb@test.local, password testpass123) for DB tests to pass.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<your-remote-anon-key>
OPENROUTER_API_KEY=<your-openrouter-key>
