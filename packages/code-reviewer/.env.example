# OpenRouter API key — the single key for all AI calls in this project.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the default model (any OpenRouter model id).
# Examples: openai/gpt-4o-mini, openai/gpt-4o, anthropic/claude-sonnet-4.5
# OPENROUTER_MODEL=openai/gpt-4o-mini
