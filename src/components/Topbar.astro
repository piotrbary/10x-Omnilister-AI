---
const { user } = Astro.locals;
---

<!-- Notion-style top nav — designed for dark (brand-navy) surfaces -->
<nav class="flex items-center justify-between px-2 py-2"
  style="border-bottom: 1px solid var(--dt-color-on-dark-muted); font-size: var(--dt-text-body-sm-size);">

  <a href="/" class="font-semibold" style="color: var(--dt-color-on-dark);">
    Omnilister AI
  </a>

  {user ? (
    <div class="flex items-center gap-4">
      <span style="color: var(--dt-color-on-dark-muted);">{user.email}</span>
      <a href="/objects" style="color: var(--dt-color-on-dark); font-weight: 500;">
        Moje obiekty
      </a>
      <form method="POST" action="/api/auth/signout">
        <button type="submit"
          class="px-4 py-2 transition-opacity hover:opacity-80"
          style="background: transparent; color: var(--dt-color-on-dark); border: 1px solid var(--dt-color-on-dark-muted); border-radius: var(--dt-radius-md);">
          Wyloguj
        </button>
      </form>
    </div>
  ) : (
    <div class="flex items-center gap-3">
      <a href="/auth/signin"
        class="px-4 py-2 transition-opacity hover:opacity-80"
        style="color: var(--dt-color-on-dark); font-weight: 500;">
        Zaloguj
      </a>
      <a href="/auth/signup"
        class="px-4 py-2 transition-opacity hover:opacity-80"
        style="background-color: var(--dt-color-primary); color: var(--dt-color-on-dark); border-radius: var(--dt-radius-md); font-weight: 500;">
        Rejestracja
      </a>
    </div>
  )}
</nav>
